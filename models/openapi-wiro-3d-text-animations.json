            "enum": [
              "16:9",
              "9:16",
              "1:1"
            ],
            "x-options": [
              {
                "value": "16:9",
                "label": "16:9"
              },
              {
                "value": "9:16",
                "label": "9:16"
              },
              {
                "value": "1:1",
                "label": "1:1"
              }
