{
  "name": "@wiroai/mcp-server",
  "version": "1.0.3",
  "description": "Unofficial MCP server for Wiro AI — integrate AI model execution into Claude, Cursor, and other MCP-compatible tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wiro-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "zod": "^4.3.6",
    "@wiroai/sdk": "^1.0.0"
  },
  "keywords": [
    "wiro",
    "ai",
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "image-generation",
    "video-generation",
    "llm"
  ],
  "author": "Ersin KOÇ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ersinkoc/wiro-ai.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://wiro.ai",
  "engines": {
    "node": ">=18.0.0"
  }
}
